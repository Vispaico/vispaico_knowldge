{
  "name": "knowledge-api",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant knowledge platform backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env.local src/server.ts",
    "build": "tsc",
    "start": "node --enable-source-maps dist/server.js",
    "migrate": "tsx --env-file .env.local src/lib/migrate-cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
